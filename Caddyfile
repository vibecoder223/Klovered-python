# Caddy reverse proxy — one box, three apps (FastAPI backend + Next.js
# marketing + Next.js tool). Auto-HTTPS via Let's Encrypt.
#
# Set DOMAIN in .env:
#   • "klovered.com www.klovered.com"  → space-separated list, real domains.
#     Caddy auto-issues + renews an HTTPS cert for EACH host listed, and the
#     @www redirect below sends www traffic to the apex so there's one
#     canonical URL. Both hostnames must already resolve (DNS A record) to
#     this Droplet's IP, or cert issuance for that host fails.
#   • "klovered.com"                   → apex only, no www redirect needed.
#   • :80                              → plain HTTP on the IP, no TLS (no
#     domain pointed here yet).
#
# Routing is by prefix, NOT a blanket /api/* → api, because the marketing site
# has its OWN /api/contact route. Only the backend's known prefixes go to the
# API; everything else (the site, its /api/contact) goes to web.

{$DOMAIN} {
	encode zstd gzip

	# Canonicalize on the apex domain. Only fires when DOMAIN actually
	# includes www.klovered.com (see comment above) — harmless no-op
	# otherwise, e.g. under :80 or an apex-only DOMAIN.
	@www host www.klovered.com
	redir @www https://klovered.com{uri} permanent

	# /api/knowledge needs BOTH the bare path (GET list, no id) and the
	# wildcard (GET/DELETE by id) — Caddy's "/x/*" matcher does not match the
	# bare "/x" with nothing after the slash.
	@backend path /health /api/auth/* /api/pipeline/* /api/knowledge /api/knowledge/* /api/cron/*
	handle @backend {
		reverse_proxy api:8000
	}

	# Self-hosted analytics (Umami) — dashboard + tracker script/collector for
	# both the marketing site and the tool. Umami has its own login, so this
	# path doesn't need a separate auth gate.
	handle /analytics* {
		reverse_proxy umami:3000
	}

	# The tool (klovered-free) runs with Next basePath /app, so every one of its
	# routes and assets lives under /app — this one rule covers them all.
	handle /app* {
		reverse_proxy tool:3100
	}

	handle {
		reverse_proxy web:3000
	}
}
