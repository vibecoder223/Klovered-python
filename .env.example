# Postgres (self-hosted). app_user = RLS request path; superuser = admin/worker.
DATABASE_URL=postgresql://app_user:app_pw@localhost:5432/klovered
ADMIN_DATABASE_URL=postgresql://klovered:klovered_pw@localhost:5432/klovered
POSTGRES_PASSWORD=klovered_pw

# Self-issued guest auth — CHANGE THIS in production (openssl rand -hex 32).
AUTH_JWT_SECRET=dev-secret-change-me

# Local-disk storage
STORAGE_DIR=./data/uploads

# Mistral (the only AI vendor: generation + embeddings + OCR)
MISTRAL_API_KEY=
LLM_API_KEY=

CRON_SECRET=

# Google OAuth (optional — leave blank to disable Google sign-in). The client
# id is public; the SECRET is sensitive, keep it only here. Google rejects
# raw-IP redirect URIs: use localhost for dev or a real domain in prod, and
# register the exact GOOGLE_REDIRECT_URI on the OAuth client in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Where the browser lands after login; the token is appended as #access_token.
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:3100/

# ---- Droplet stack (docker-compose.stack.yml) ----
# Caddy site address. A real domain -> auto-HTTPS; ":80" -> plain HTTP on the IP.
DOMAIN=:80
# Marketing site: where its "Sign in / Start free trial" CTAs point. Inlined at
# BUILD time, so rebuild the web image after changing it.
NEXT_PUBLIC_APP_URL=
# Marketing contact form (Resend), server-side at runtime.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_FROM=
