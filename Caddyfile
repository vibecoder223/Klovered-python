# Caddy reverse proxy — one box, two apps (FastAPI backend + Next.js marketing).
#
# Set DOMAIN in .env:
#   • a real domain (e.g. klovered.io) → Caddy auto-issues + renews HTTPS
#   • :80                              → plain HTTP on the IP (no domain yet)
#
# Routing is by prefix, NOT a blanket /api/* → api, because the marketing site
# has its OWN /api/contact route. Only the backend's known prefixes go to the
# API; everything else (the site, its /api/contact) goes to web.

{$DOMAIN} {
	encode zstd gzip

	@backend path /health /api/auth/* /api/pipeline/* /api/knowledge/* /api/cron/*
	handle @backend {
		reverse_proxy api:8000
	}

	# The tool (klovered-free) runs with Next basePath /app, so every one of its
	# routes and assets lives under /app — this one rule covers them all.
	handle /app* {
		reverse_proxy tool:3100
	}

	handle {
		reverse_proxy web:3000
	}
}
